---
---

<header class="hero-section" id="top">
  <!-- Background Image with Gradient Overlay -->
  <div class="hero-bg"></div>

  <div class="hero-content container reveal reveal-up">
    <div class="hero-card">
      <div class="hero-card-inner">
        <!-- Logo -->
        <img
          src="/RDK-digital-Jambi-/img/Logo_Kementerian_Kependudukan_dan_Pembangunan_Keluarga_-_BKKBN_(2024)_(cropped).svg.png"
          alt="Logo BKKBN"
          class="hero-logo animate-float"
        />

        <!-- Text -->
        <div class="text-content">
          <h1 class="hero-title">Rumah DataKu</h1>
          <div class="decorative-line"></div>
          <h2 class="hero-subtitle text-gradient-gold">PROVINSI JAMBI</h2>
          <p class="hero-desc">
            Portal Data Resmi Kementerian Kependudukan dan Pembangunan Keluarga.
            Membangun keluarga berkualitas dengan akses data yang cepat, akurat,
            dan terpercaya.
          </p>
        </div>

        <!-- Social -->
        <div class="social-links-hero mt-4">
          <a
            href="https://www.facebook.com/bkkbnjambiofficial?locale=id_ID"
            target="_blank"
            aria-label="Facebook"
            ><i class="fa-brands fa-facebook"></i>
          </a>
          <a
            href="http://www.youtube.com/@bkkbnjambiofficial"
            target="_blank"
            aria-label="YouTube"
            ><i class="fa-brands fa-youtube"></i>
          </a>
          <a
            href="https://www.instagram.com/kemendukbangga_bkkbnjambi?utm_source=ig_web_button_share_sheet&igsh=ZDNlZDc0MzIxNw=="
            target="_blank"
            aria-label="Instagram"
            ><i class="fa-brands fa-instagram"></i>
          </a>
        </div>
      </div>
    </div>
  </div>
</header>

<style>
  .hero-section {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: 6rem 0;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    /* PENTING: Nama file gambar dari user disetel ke hero-group.jpg */
    background: url("/RDK-digital-Jambi-/img/hero-group.jpg") no-repeat center center;
    background-size: cover;
    background-attachment: fixed;
  }

  .hero-bg::after {
    content: "";
    position: absolute;
    inset: 0;
    /* Gradien overlay biru ke gelap agar teks tetap terbaca */
    background: linear-gradient(
      135deg,
      rgba(10, 81, 117, 0.75) 0%,
      rgba(15, 23, 42, 0.95) 100%
    );
  }

  .hero-content {
    position: relative;
    z-index: 10;
    width: 100%;
    display: flex;
    justify-content: center;
  }

  .hero-card {
    position: relative;
    max-width: 800px;
    width: 100%;
    background: transparent;
    box-shadow: none;
    transform: translateY(-15vh); /* Menggeser teks ke atas sedikit */
  }

  .hero-card-inner {
    background: transparent;
    padding: 4rem 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .hero-logo {
    width: 150px;
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0 10px 15px rgba(0, 0, 0, 0.4));
    margin-bottom: 2.5rem;
  }

  .text-content {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hero-title {
    font-size: clamp(3rem, 8vw, 5rem);
    font-weight: 900;
    line-height: 1.1;
    color: var(--text-main);
    margin-bottom: 1rem;
    text-shadow: 0 4px 10px rgba(0, 0, 0, 0.5);
  }

  .decorative-line {
    width: 80px;
    height: 4px;
    background: linear-gradient(90deg, var(--accent), var(--accent-light));
    border-radius: 2px;
    margin: 1rem 0 1.5rem;
  }

  .hero-subtitle {
    font-size: clamp(1.2rem, 3vw, 1.8rem);
    font-weight: 600;
    margin-bottom: 1.5rem;
    letter-spacing: 0.15em;
  }

  .hero-desc {
    font-size: 1.15rem;
    color: rgba(255, 255, 255, 0.9);
    line-height: 1.8;
    max-width: 600px;
    margin: 0 auto;
  }

  .social-links-hero {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
  }

  .social-links-hero a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 50px;
    height: 50px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.1);
    color: white;
    font-size: 1.5rem;
    border: 1px solid rgba(255, 255, 255, 0.2);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .social-links-hero a:hover {
    background: var(--accent);
    color: #1a1a1a;
    transform: translateY(-5px);
    border-color: var(--accent);
    box-shadow: 0 10px 20px rgba(244, 180, 0, 0.3);
  }

  .mt-4 {
    margin-top: 2.5rem;
  }

  @media (max-width: 768px) {
    .hero-card-inner {
      padding: 3rem 1.5rem;
    }
  }
</style>
