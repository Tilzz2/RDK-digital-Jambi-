---
const services = [
  {
    title: "Format Surat Permohonan",
    image: "/img/Format Surat Permohonan.docx.jpg",
    link: "/service/Format Surat Permohonan.docx",
    desc: "Unduh dokumen format surat permohonan."
  },
  {
    title: "Perjanjian Kerja Sama",
    image: "/img/Format Perjanjian Kerja Sama Pemanfaatan Data dan Informasi Keluarga.docx.jpg",
    link: "/service/Format Perjanjian Kerja Sama Pemanfaatan Data dan Informasi Keluarga.docx",
    desc: "Unduh dokumen perjanjian kerja sama."
  },
  {
    title: "Surat Perjanjian Penggunaan Data",
    image: "/img/Surat Perjanjian Penggunaan Data.docx.jpg",
    link: "/service/Surat Perjanjian Penggunaan Data.docx",
    desc: "Unduh dokumen perjanjian penggunaan data."
  },
  {
    title: "Berita Acara Serah Terima",
    image: "/img/Berita Acara Serah Terima.docx.jpg",
    link: "/service/Berita Acara Serah Terima.docx",
    desc: "Unduh dokumen berita acara serah terima."
  }
];
---

<section id="services" class="services-section section-padding">
  <div class="container">
    <div class="section-header reveal reveal-up">
      <h2 class="section-title">LAMPIRAN PERATURAN</h2>
      <h3 class="section-subtitle">
        BADAN KEPENDUDUKAN DAN KELUARGA BERENCANA NASIONAL<br>
        REPUBLIK INDONESIA NOMOR 6 TAHUN 2022 TENTANG
      </h3>
      <h4 class="section-highlight text-gradient-gold">PEMANFAATAN DATA DAN INFORMASI KELUARGA</h4>
      <div class="header-divider"></div>
    </div>

    <div class="services-grid">
      {services.map((service, index) => (
        <div class="service-card glass-panel reveal reveal-up" style={`transition-delay: ${index * 150}ms`}>
          <div class="card-image-wrapper">
            <img src={service.image} alt={service.title} class="card-image" loading="lazy" />
            <div class="card-overlay">
              <a href={service.link} target="_blank" class="btn btn-primary download-btn">
                <i class="fa-solid fa-download mr-2"></i> Unduh
              </a>
            </div>
          </div>
          <div class="card-content">
            <h4 class="card-title">{service.title}</h4>
            <p class="card-desc">{service.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .services-section {
    background: linear-gradient(180deg, var(--bg-dark) 0%, #0d2136 100%);
    position: relative;
  }

  .section-header {
    text-align: center;
    margin-bottom: 5rem;
  }

  .section-title {
    font-size: 1rem;
    color: var(--text-muted);
    letter-spacing: 0.3em;
    margin-bottom: 1rem;
  }

  .section-subtitle {
    font-size: clamp(1.2rem, 2.5vw, 1.8rem);
    font-weight: 400;
    line-height: 1.4;
    margin-bottom: 1rem;
  }

  .section-highlight {
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    font-weight: 800;
    margin-bottom: 2rem;
  }

  .header-divider {
    width: 60px;
    height: 4px;
    background: var(--accent);
    margin: 0 auto;
    border-radius: 2px;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2.5rem;
    padding: 1rem;
  }

  .service-card {
    overflow: hidden;
    transition: var(--transition);
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .service-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
    border-color: rgba(61, 126, 216, 0.3);
  }

  .card-image-wrapper {
    position: relative;
    width: 100%;
    padding-top: 141%; /* A4 aspect ratio approximation */
    overflow: hidden;
  }

  .card-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    transition: transform 0.5s ease;
  }

  .service-card:hover .card-image {
    transform: scale(1.05);
  }

  .card-overlay {
    position: absolute;
    inset: 0;
    background: rgba(10, 81, 117, 0.8);
    backdrop-filter: blur(4px);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: var(--transition);
  }

  .service-card:hover .card-overlay {
    opacity: 1;
  }

  .download-btn {
    transform: translateY(20px);
    opacity: 0;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .service-card:hover .download-btn {
    transform: translateY(0);
    opacity: 1;
  }

  .card-content {
    padding: 1.5rem;
    text-align: center;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  .card-title {
    font-size: 1.2rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: var(--text-main);
  }

  .card-desc {
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  .mr-2 { margin-right: 0.5rem; }
</style>
